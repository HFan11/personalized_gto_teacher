{
  "name": "pokergto",
  "version": "1.0.0",
  "description": "PokerGTO - Texas Hold'em GTO Strategy Trainer with CFR+ Solver",
  "private": true,
  "scripts": {
    "dev": "python3 -m http.server 8080 --directory web",
    "test": "node lib/test-solver.js",
    "calibrate": "node lib/calibrate-solver.js",
    "calibrate:all": "node lib/calibrate-solver.js --all",
    "batch:flop": "node solver/precompute/batch-solve.js --flop",
    "batch:flop:force": "node solver/precompute/batch-solve.js --flop --force",
    "batch:turn": "node solver/precompute/batch-solve.js --turn"
  }
}
